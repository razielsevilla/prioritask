{
  "manifest_version": 3,
  "name": "PrioriTask",
  "version": "1.0.1",
  "description": "Prioritize assignments and manage decision fatigue.",
  "permissions": ["storage", "alarms", "notifications"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}